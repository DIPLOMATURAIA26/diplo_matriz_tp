# ARCHIVO DE VARIABLES DE ENTORNO DE EJEMPLO
# Copia este archivo como ".env" (para desarrollo local) o agrégalas en Vercel

# 1. CLAVE DE API DE GEMINI (Google AI Studio)
# Obligatoria en el Backend (server.ts) para la generación de reportes y consultas.
GEMINI_API_KEY="tu_api_key_de_gemini_aqui"

# 2. CREDENCIALES DE CONEXIÓN CON SUPABASE (SUPABASE REAL)
# Obligatorias en el Frontend (Vite) para persistir Matriz, Umbrales y Reportes.
# Comienzan con VITE_ para que estén expuestas al cliente de forma segura (clave anon_key).
VITE_SUPABASE_URL="https://smebnmtldditllnyfsgq.supabase.co"
VITE_SUPABASE_ANON_KEY="tu_anon_public_key_de_supabase_aqui"

# NOTA: Obtén VITE_SUPABASE_ANON_KEY de:
# Dashboard Supabase → Settings → API → anon public key
