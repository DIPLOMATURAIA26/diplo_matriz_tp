# ============================================
# ARCHIVO DE VARIABLES DE ENTORNO DE EJEMPLO
# ============================================
# Para DESARROLLO LOCAL:
# - Copia este archivo como ".env" (sin "example")
# - Completa las variables con tus valores reales
#
# Para PRODUCCIÓN EN VERCEL:
# - NO necesitas archivo .env local
# - Agrega las variables en: Settings → Environment Variables
# ============================================

# 1. GEMINI API KEY (Google AI Studio)
# Obtén tu clave en: https://aistudio.google.com/app/apikeys
GEMINI_API_KEY="tu_api_key_de_gemini_aqui"

# 2. SUPABASE URL (Proyecto)
# Encontrada en: Supabase Dashboard → Settings → API → Project URL
VITE_SUPABASE_URL="https://tu-proyecto.supabase.co"

# 3. SUPABASE ANON KEY (Clave pública)
# Encontrada en: Supabase Dashboard → Settings → API → anon public
VITE_SUPABASE_ANON_KEY="tu_anon_public_key_de_supabase_aqui"
