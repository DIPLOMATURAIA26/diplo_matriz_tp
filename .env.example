# ============================================
# ARCHIVO DE VARIABLES DE ENTORNO DE EJEMPLO
# ============================================
# Para DESARROLLO LOCAL (si quieres npm run dev):
# - Copia este archivo como ".env" en la raíz
# - Completa las variables
#
# Para PRODUCCIÓN EN VERCEL:
# - Agrégalas en: Settings → Environment Variables
# - NO necesitas archivo .env local
# ============================================

# 1. CLAVE DE API DE GEMINI
# Obtén en: https://aistudio.google.com/app/apikeys
GEMINI_API_KEY="tu_api_key_de_gemini_aqui"

# 2. SUPABASE URL (Proyecto real)
# Encontrada en: Dashboard Supabase → Settings → API
VITE_SUPABASE_URL="https://smebnmtldditllnyfsgq.supabase.co"

# 3. SUPABASE ANON KEY (Clave pública)
# Encontrada en: Dashboard Supabase → Settings → API → anon public
VITE_SUPABASE_ANON_KEY="tu_anon_public_key_de_supabase_aqui"
